{
  "name": "decode-ton-esprit",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist --d1=decode-ton-esprit-db --local",
    "dev:sandbox": "wrangler pages dev dist --d1=decode-ton-esprit-db --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist --project-name decode-ton-esprit",
    "db:migrate:local": "wrangler d1 migrations apply decode-ton-esprit-db --local",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
