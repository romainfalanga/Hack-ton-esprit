{
  "name": "hack-ton-esprit",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-assets",
    "copy-assets": "mkdir -p dist/assets/static && cp -r public/static/* dist/assets/static/ 2>/dev/null || true",
    "preview": "wrangler dev --d1=hack-ton-esprit-db --local",
    "dev:sandbox": "wrangler dev --d1=hack-ton-esprit-db --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hack-ton-esprit-db --local",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local"
  },
  "dependencies": {
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
